# いちカズ 環境変数（systemd EnvironmentFile=/root/ichikazu/.env で読み込まれる）

# 管理画面の認証情報
ADMIN_USER=admin
ADMIN_PASS=your-strong-password-here

# アカウント（JWT署名鍵。変更すると既存ログインが無効化される）
JWT_SECRET=change-me-to-a-long-random-string

# 決済（Stripe）
APP_URL=https://1qaz.jp
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx
